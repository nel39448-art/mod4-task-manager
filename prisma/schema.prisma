// Esquema de Prisma para el gestor de tareas (Sesión 5)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tarea {
  id         Int     @id @default(autoincrement())
  titulo     String
  completada Boolean @default(false)
}
